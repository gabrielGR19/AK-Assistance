# Vorlage für .env.local (nicht committen, siehe .gitignore).

# Live-Abruf Claude-API-Guthaben (Anthropic Cost Report API, Admin-Key).
ANTHROPIC_ADMIN_KEY=

# Live-Abruf Retell.ai Call-Kosten.
RETELL_API_KEY=

# Basic-Auth-Passwort fürs gesamte Cockpit. Ohne gesetzten Wert ist das Cockpit ungeschützt
# (nur für lokale Entwicklung so lassen).
COCKPIT_PASSWORT=

# Gültige Benutzernamen für den Basic-Auth-Dialog, kommagetrennt (z.B. Gabriel,Moritz).
# Im Login-Dialog müssen jetzt BEIDE Felder stimmen: ein hier gelisteter Name UND das
# oben gesetzte COCKPIT_PASSWORT.
COCKPIT_BENUTZERNAMEN=

# Server-zu-Server-Secret für Crontab-Skripte (scripts/live-refresh.sh,
# scripts/erinnerung-telegram.sh) — umgeht die Basic-Auth NUR für /api/live/refresh und
# /api/reminders, NUR mit exakt passendem Header. Frei wählbarer, langer Zufallswert.
COCKPIT_CRON_SECRET=

# Telegram-Bot für Erinnerungen (scripts/erinnerung-telegram.sh). Bot via @BotFather anlegen,
# einmal /start senden, Token + Chat-ID eintragen.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
