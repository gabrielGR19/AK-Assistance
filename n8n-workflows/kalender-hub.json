      "parameters": {
        "jsCode": "const allEvents = $('Get All Events').all().map(i => i.json).filter(function(e) { return e.start && e.start.dateTime; });\nconst callerPhone = ($('Check & Book').item.json.body.caller_phone || '').replace(/[\\s\\-\\(\\)]/g, '');\nconst digits = callerPhone.replace(/^\\+49/, '0');\n\nconst existing = allEvents.find(function(ev) {\n  const desc = (ev.description || '').replace(/[\\s\\-\\(\\)]/g, '');\n  return digits.length >= 8 && (desc.includes(digits) || desc.includes(callerPhone));\n});\n\nif (existing) {\n  const start = DateTime.fromISO(existing.start.dateTime).setZone('Europe/Berlin');\n  const formatted = start.setLocale('de').toFormat(\"cccc, dd. MMMM 'um' HH:mm 'Uhr'\");\n  return [{ json: {\n    alreadyBooked: true,\n    existingDate: existing.start.dateTime,\n    existingDateFormatted: formatted,\n    existingSummary: existing.summary\n  }}];\n}\nreturn [{ json: { alreadyBooked: false } }];"
      },
