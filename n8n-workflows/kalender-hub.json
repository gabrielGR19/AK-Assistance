    {
      "parameters": {
        "jsCode": "const allEvents = $('Get All Events').all().map(i => i.json).filter(function(e) { return e.start && e.start.dateTime; });\nconst config = $('Workflow Configuration').item.json;\nconst webhookBody = $('Check & Book').item.json.body;\n\nconst requestedDate = webhookBody.requested_date;\nconst slotDuration = config.slotDurationMinutes || 60;\nconst tz = config.timezone || 'Europe/Berlin';\nconst businessStart = config.businessHoursStart || 10;\nconst businessEnd = config.businessHoursEnd || 17;\n\nconst slotStart = DateTime.fromISO(requestedDate, { zone: tz });\nconst slotEnd = slotStart.plus({ minutes: slotDuration });\n\nif (!slotStart.isValid) {\n  return [{ json: { slotAvailable: false, reason: 'invalid_date' } }];\n}\n\nconst isSunday = slotStart.weekday === 7;\nconst isTooEarly = slotStart.hour < businessStart;\nconst isTooLate = slotEnd.hour > businessEnd || (slotEnd.hour === businessEnd && slotEnd.minute > 0);\n\nif (isSunday || isTooEarly || isTooLate) {\n  return [{ json: { slotAvailable: false, reason: isSunday ? 'sunday_closed' : 'outside_business_hours' } }];\n}\n\nconst hasConflict = allEvents.some(function(ev) {\n  var evStart = DateTime.fromISO(ev.start.dateTime);\n  var evEnd = DateTime.fromISO(ev.end.dateTime);\n  return slotStart < evEnd && slotEnd > evStart;\n});\n\nreturn [{ json: { slotAvailable: !hasConflict } }];"
      },
