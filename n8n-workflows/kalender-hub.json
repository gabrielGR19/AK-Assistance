    {
      "parameters": {
        "jsCode": "const raw = ($('Check & Book').item.json.body.caller_email || '').trim();\nconst strictEmail = /^[^\\s@\"'\\\\]+@[^\\s@\"'\\\\]+\\.[^\\s@\"'\\\\]+$/;\nconst noLetter = '(?<![a-zäöü])';\nconst noLetterAhead = '(?![a-zäöü])';\n\nconst digitWords = { null:'0', eins:'1', zwei:'2', drei:'3', vier:'4', fuenf:'5', 'fünf':'5', sechs:'6', sieben:'7', acht:'8', neun:'9' };\n\nfunction wordRegex(alternatives) {\n  return new RegExp('\\\\s*' + noLetter + '(?:' + alternatives + ')' + noLetterAhead + '\\\\s*', 'g');\n}\n\nfunction normalize(input) {\n  if (strictEmail.test(input)) return input;\n  const n = input\n    .toLowerCase()\n    .replace(wordRegex('at|ät'), '@')\n    .replace(wordRegex('punkt|dot|pkt'), '.')\n    .replace(wordRegex('unterstrich|underscore'), '_')\n    .replace(wordRegex('minus|bindestrich|dash'), '-')\n    .replace(/(?<![a-zäöü])(null|eins|zwei|drei|vier|fuenf|fünf|sechs|sieben|acht|neun)(?![a-zäöü])/g, function(w) { return digitWords[w]; })\n    .replace(/\\s+/g, '');\n  return strictEmail.test(n) ? n : '';\n}\n\nreturn [{ json: { attendeeEmail: normalize(raw) } }];"
      },
