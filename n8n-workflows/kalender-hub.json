    {
      "parameters": {
        "jsCode": "const events = $('Get All Events').all().map(i => i.json).filter(e => e.start?.dateTime);\n\nconst config = $('Workflow Configuration').item.json;\nconst slotDuration = config.slotDurationMinutes || 60;\nconst businessStart = config.businessHoursStart || 10;\nconst businessEnd   = config.businessHoursEnd   || 17;\nconst tz = config.timezone || 'Europe/Berlin';\n\nconst requestedDate = $('Check & Book').item.json.body?.requested_date;\nlet current = DateTime.fromISO(requestedDate, { zone: tz });\nif (!current.isValid) current = DateTime.now().setZone(tz);\nif (current < DateTime.now().setZone(tz)) current = DateTime.now().setZone(tz);\nconst remainder = current.minute % slotDuration;\nif (remainder !== 0) current = current.plus({ minutes: slotDuration - remainder });\ncurrent = current.set({ second: 0, millisecond: 0 });\n\n// Search up to 21 days from requested date so we always find alternatives\nconst maxDate = DateTime.fromISO(requestedDate, { zone: tz }).isValid\n  ? DateTime.fromISO(requestedDate, { zone: tz }).plus({ days: 21 })\n  : DateTime.now().setZone(tz).plus({ days: 21 });\nconst alternatives = [];\n\nwhile (alternatives.length < 2 && current < maxDate) {\n  if (current.weekday === 7) {\n    current = current.plus({ days: 1 }).set({ hour: businessStart, minute: 0, second: 0 });\n    continue;\n  }\n  if (current.hour < businessStart) {\n    current = current.set({ hour: businessStart, minute: 0, second: 0 });\n    continue;\n  }\n  const slotEnd = current.plus({ minutes: slotDuration });\n  if (current.hour >= businessEnd || slotEnd.hour > businessEnd || (slotEnd.hour === businessEnd && slotEnd.minute > 0)) {\n    current = current.plus({ days: 1 }).set({ hour: businessStart, minute: 0, second: 0 });\n    continue;\n  }\n  const occupied = events.some(ev => {\n    const evStart = DateTime.fromISO(ev.start.dateTime);\n    const evEnd   = DateTime.fromISO(ev.end.dateTime);\n    return current < evEnd && slotEnd > evStart;\n  });\n  if (!occupied) alternatives.push(current.toISO());\n  current = slotEnd;\n}\n\nreturn [{ json: { alternativeSlots: alternatives } }];"
      },
