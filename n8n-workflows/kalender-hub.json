      "id": "23582fc9-e04f-4313-9bd6-712fe51f4e76",
      "name": "Get Events",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [
        400,
        896
      ],
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "EJoFwmsXROHavQ1a",
          "name": "Google Calendar account 2"
        }
