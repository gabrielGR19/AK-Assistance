      "parameters": {
        "operation": "getAll",
        "calendar": {
          "__rl": true,
          "value": "={{ $('Workflow Configuration').item.json.calendarId }}",
          "mode": "id"
        },
        "timeMin": "={{ DateTime.now().setZone('Europe/Berlin').toISO() }}",
